# === VetClinic — variables de entorno (plantilla) ===
# Copia a .env.local y rellena. NUNCA subas .env.local al repo.

# ── App ──
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase (proyecto NUEVO, región UE) ──
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ── Stripe (suscripción al SaaS) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Price IDs de cada plan (créalos en Stripe → Productos)
STRIPE_PRICE_BASICO=
STRIPE_PRICE_PRO=
STRIPE_PRICE_CLINICA=

# ── Resend (emails transaccionales) ──
RESEND_API_KEY=
EMAIL_FROM=VetClinic <no-reply@vetclinic.com>

# ── LLM (chatbot asistente + agente IA WhatsApp) ──
OPENAI_API_KEY=
GEMINI_MODE=mock
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# ── Blog CMS ──
CRON_SECRET=

# ── WhatsApp Cloud API (Meta) — mock por defecto ──
WHATSAPP_MODE=mock
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=vetclinic_webhook_verify
WHATSAPP_APP_SECRET=

# ── n8n (automatizaciones / recordatorios) ──
N8N_WEBHOOK_BASE=
N8N_API_KEY=
